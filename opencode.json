{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@warp-dot-dev/opencode-warp"],
  "formatter": false,
  "provider": {
    "mimo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiMo Token Plan",
      "env": ["MIMO_API_KEY"],
      "options": {
        "baseURL": "https://token-plan-sgp.xiaomimimo.com/v1"
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "mimo-v2.5-pro",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "mimo-v2.5": {
          "name": "mimo-v2.5",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1"
      },
      "models": {
        "minimaxai/minimax-m2.5": {}
      }
    }
  },
  "mcp": {

    "figma": {
      "type": "local",
      "command": "npx",
      "enabled": false,
      "args": [
        "-y",
        "figma-developer-mcp",
        "--figma-api-key",
        "your-figma-api-key"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "sonarqube": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "sonarqube-mcp-server@latest"
      ],
      "enabled": false,
      "timeout": 10000,
      "environment": {
        "SONARQUBE_URL": "https://sonarqube.fleetenable.com",
        "SONARQUBE_TOKEN": "your-sonarqube-token"
      }
    }
  }
}
