{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@warp-dot-dev/opencode-warp"],
  "formatter": false,
  "provider": {
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1"
      },
      "models": {
        "minimaxai/minimax-m2.5": {}
      }
    }
  },
  "mcp": {

    "figma": {
      "type": "local",
      "command": "npx",
      "enabled": false,
      "args": [
        "-y",
        "figma-developer-mcp",
        "--figma-api-key",
        "your-figma-api-key"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "sonarqube": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "sonarqube-mcp-server@latest"
      ],
      "enabled": false,
      "timeout": 10000,
      "environment": {
        "SONARQUBE_URL": "https://sonarqube.fleetenable.com",
        "SONARQUBE_TOKEN": "your-sonarqube-token"
      }
    }
  }
}
